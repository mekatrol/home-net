#!/bin/bash
# Watchdog command dispatcher
#
# Installed on each monitored Pi at /usr/local/bin/watchdog-dispatch
# and referenced from the watchdog user's authorized_keys via command=
#
# The monitor container sends a named command (e.g. "reboot") over SSH.
# This script validates it against an explicit allowlist before acting.
# Any command not on the list is silently rejected.

set -euo pipefail

case "${SSH_ORIGINAL_COMMAND:-}" in
    reboot)
        exec sudo /sbin/reboot
        ;;
    upgrade)
        sudo apt-get update && sudo apt-get upgrade -y
        ;;
    upgrade_reboot)
        sudo apt-get update
        sudo apt-get upgrade -y
        sudo apt-get autoremove -y
        sudo reboot
        ;;
    *)
        echo "watchdog-dispatch: command not permitted: '${SSH_ORIGINAL_COMMAND:-}'" >&2
        exit 1
        ;;
esac
